# .env.example

# Token do Bot do Telegram
TELEGRAM_TOKEN=
# ID do Google Calendar (visível nas configurações do calendário compartilhado)
GOOGLE_CALENDAR_ID=

# Dados para envio de e-mail de confirmação
EMAIL_USER=fchnet@gmail.com
EMAIL_PASSWORD=  # ou senha gerada para aplicativo
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# Caminho da imagem de boas-vindas (pode ser alterado se for remoto)
IMAGE_PATH=image/maria_de_nazare.png

# Configurações de horários de atendimento
START_HOUR=8
END_HOUR=17
APPOINTMENT_DURATION_MINUTES=60
MAX_CONCURRENT_APPOINTMENTS=5
MAX_APPOINTMENTS_PER_DAY=90
